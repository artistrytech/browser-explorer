// アプリ設定 (JSONC: // や /* */ のコメントを書けます。末尾カンマは不可)
//
// ここで設定するのは再起動が必要な項目のみです。
// コミット変更ファイルの表示上限・コンテキストメニュー・外部ツール・差分ツール・
// 拡張子ごとの既定ツールは、アプリの「設定」画面 (GUI) で編集し DB に保存します
// (再起動なしで即時反映。設定画面のエクスポート/インポートで持ち出し可)。
{
  // サーバの待受アドレス (127.0.0.1 固定を推奨)
  "host": "127.0.0.1",
  // API サーバのポート
  "port": 5175,
  // 開発用クライアント (vite) のポート
  "clientPort": 5173,
  // API 認証トークン (x-app-token ヘッダで全 API に要求される)
  "token": "eb-7f3c9a1d5e8b4620c4d2a6f0b9e17358"
}
